ErrorDocument 404 /404.html
DirectoryIndex index.html

# Redirections 301 — anciennes pages vers accueil
Redirect 301 /tarifs /
Redirect 301 /tarifs/ /
Redirect 301 /apropos /
Redirect 301 /apropos/ /
Redirect 301 /a-propos /
Redirect 301 /a-propos/ /
Redirect 301 /about /
Redirect 301 /about/ /
Redirect 301 /contact /
Redirect 301 /contact/ /

# NOTE: Les redirections trailing slash (/photobooth, /mariage, /blog)
# ont été supprimées car next.config.ts gère déjà cela avec trailingSlash: true.
# Les conserver créait une boucle de redirection infinie (ERR_TOO_MANY_REDIRECTS).
